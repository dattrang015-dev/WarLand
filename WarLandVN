-- 1. Tạo giao diện gốc
local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local Title = Instance.new("TextLabel")
local AutoClickBtn = Instance.new("TextButton")

ScreenGui.Parent = game.CoreGui
ScreenGui.Name = "WarLandVN_Custom"

-- 2. Chỉnh bảng chính (Main Frame)
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.Position = UDim2.new(0.4, 0, 0.4, 0)
MainFrame.Size = UDim2.new(0, 200, 0, 150)
MainFrame.Active = true
MainFrame.Draggable = true -- Có thể kéo di chuyển

-- 3. Tiêu đề
Title.Parent = MainFrame
Title.Size = UDim2.new(1, 0, 0, 30)
Title.Text = "WARLAND VN"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.BackgroundColor3 = Color3.fromRGB(50, 50, 50)

-- 4. Nút Auto Click
AutoClickBtn.Parent = MainFrame
AutoClickBtn.Size = UDim2.new(0.8, 0, 0, 40)
AutoClickBtn.Position = UDim2.new(0.1, 0, 0.4, 0)
AutoClickBtn.Text = "Bật Auto Click"
AutoClickBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)

-- LOGIC HACK
_G.AutoClick = false
AutoClickBtn.MouseButton1Click:Connect(function()
    _G.AutoClick = not _G.AutoClick
    if _G.AutoClick then
        AutoClickBtn.Text = "Đang Auto: BẬT"
        AutoClickBtn.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
    else
        AutoClickBtn.Text = "Bật Auto Click"
        AutoClickBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    end
    
    spawn(function()
        while _G.AutoClick do
            task.wait(0.1)
            pcall(function()
                game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Attack")
            end)
        end
    end)
end)
