-- 1. Auto Click
_G.AutoClick = false
CreateButton("Auto Click: TẮT", Color3.fromRGB(70, 70, 70), function(self)
    _G.AutoClick = not _G.AutoClick
    if _G.AutoClick then
        game:GetService("TextButton").Text = "Auto Click: ĐANG BẬT"
        game:GetService("TextButton").BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    else
        game:GetService("TextButton").Text = "Auto Click: TẮT"
        game:GetService("TextButton").BackgroundColor3 = Color3.fromRGB(70, 70, 70)
    end
    spawn(function()
        while _G.AutoClick do
            task.wait(0.1)
            pcall(function()
                game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Attack")
            end)
        end
    end)
end)

-- 2. Gom Quái (Bring Mobs - Cơ bản)
CreateButton("Gom Quái Lại Gần", Color3.fromRGB(0, 120, 215), function()
    local playerPos = game.Players.LocalPlayer.Character.HumanoidRootPart.Position
    for i, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
        if v:FindFirstChild("HumanoidRootPart") then
            v.HumanoidRootPart.CFrame = CFrame.new(playerPos + Vector3.new(0, 0, 5))
            v.HumanoidRootPart.CanCollide = false
        end
    end
end)

