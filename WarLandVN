local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/shlexware/Rayfield/main/source'))()

local Window = Rayfield:CreateWindow({
   Name = "WarLand VN | Blox Fruits",
   LoadingTitle = "Đang khởi động WarLand...",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "WarLand_Data",
      FileName = "MainConfig"
   },
   Discord = {
      Enabled = false,
      Invite = "",
      RememberJoins = true
   },
})

-- 1. Tab chính cho các tính năng tự động
local MainTab = Window:CreateTab("Cày Cuốc", 4483362458)

_G.AutoClick = false

MainTab:CreateToggle({
   Name = "Auto Click (Đánh siêu nhanh)",
   CurrentValue = false,
   Flag = "ToggleClick", 
   Callback = function(Value)
      _G.AutoClick = Value
      spawn(function()
         while _G.AutoClick do
            task.wait(0.1)
            -- Mã đánh mẫu cho Blox Fruits
            pcall(function()
                game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Attack")
            end)
         end
      end)
   end,
})

-- 2. Tab cho nhân vật (Người chơi)
local PlayerTab = Window:CreateTab("Người Chơi", 4483362458)

PlayerTab:CreateSlider({
   Name = "Tốc độ chạy (WalkSpeed)",
   Range = {16, 300},
   Increment = 1,
   Suffix = "Speed",
   CurrentValue = 16,
   Flag = "SliderSpeed",
   Callback = function(Value)
      game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = Value
   end,
})

PlayerTab:CreateSlider({
   Name = "Sức mạnh nhảy (JumpPower)",
   Range = {50, 500},
   Increment = 1,
   Suffix = "Power",
   CurrentValue = 50,
   Flag = "SliderJump",
   Callback = function(Value)
      game.Players.LocalPlayer.Character.Humanoid.JumpPower = Value
   end,
})

-- 3. Tab Thông tin
local InfoTab = Window:CreateTab("Thông Tin", 4483362458)

InfoTab:CreateButton({
   Name = "Kiểm tra phiên bản",
   Callback = function()
       Rayfield:Notify({
          Title = "WarLand VN",
          Content = "Bạn đang sử dụng phiên bản Full mới nhất!",
          Duration = 5,
       })
   end,
})

Rayfield:LoadConfiguration()
