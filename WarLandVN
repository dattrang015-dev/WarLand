local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/shlexware/Rayfield/main/source'))()

local Window = Rayfield:CreateWindow({
   Name = "WarLand VN | Blox Fruits",
   LoadingTitle = "Đang khởi động WarLand...",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "WarLand_Data",
      FileName = "MainConfig"
   },
})

-- 1. Tab chính
local MainTab = Window:CreateTab("Cày Cuốc", 4483362458)

-- 2. Biến điều khiển (Tắt/Bật)
_G.AutoFarm = false
_G.AutoClick = false

-- 3. Chức năng Auto Farm (Gom quái mẫu)
MainTab:CreateToggle({
   Name = "Auto Farm Level (Gom quái)",
   CurrentValue = false,
   Flag = "ToggleFarm", 
   Callback = function(Value)
      _G.AutoFarm = Value
      while _G.AutoFarm do
         task.wait(0.1)
         -- Logic: Tìm quái, bay tới quái sẽ viết thêm ở đây
         print("Đang tìm mục tiêu...")
      end
   end,
})

-- 4. Chức năng Auto Click (Đánh)
MainTab:CreateToggle({
   Name = "Auto Click (Siêu nhanh)",
   CurrentValue = false,
   Flag = "ToggleClick", 
   Callback = function(Value)
      _G.AutoClick = Value
      spawn(function()
         while _G.AutoClick do
            task.wait(0.1) -- Tốc độ đánh
            -- DÁN MÃ TỪ SIMPLESPY VÀO DƯỚI ĐÂY
            local args = { [1] = "Attack" }
            game:GetService("ReplicatedStorage").Remotes.Validator:FireServer(unpack(args))
            game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Attack", unpack(args))
         end
      end)
   end,
})

-- 5. Tab Tiện ích
local MiscTab = Window:CreateTab("Tiện ích", 4483362458)

MiscTab:CreateButton({
   Name = "Nhập Code Blox Fruits mới nhất",
   Callback = function()
       print("Đã nhấn nhập code!")
       -- Thêm danh sách code vào đây
   end,
})

MiscTab:CreateSlider({
   Name = "Tốc độ chạy (WalkSpeed)",
   Range = {16, 300},
   Increment = 1,
   Suffix = "Speed",
   CurrentValue = 16,
   Flag = "SliderSpeed",
   Callback = function(Value)
      game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = Value
   end,
})

Rayfield:LoadConfiguration()
