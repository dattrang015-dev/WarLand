local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/shlexware/Rayfield/main/source'))()

local Window = Rayfield:CreateWindow({
   Name = "WarLand VN | Blox Fruits",
   LoadingTitle = "Đang khởi động hệ thống...",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "WarLand_Data",
      FileName = "MainConfig"
   },
   Discord = {
      Enabled = false,
      Invite = "",
      RememberJoins = true
   },
})

-- ================= TAB CÀY CUỐC =================
local MainTab = Window:CreateTab("Cày Cuốc", 4483362458)

_G.AutoClick = false
MainTab:CreateToggle({
   Name = "Auto Click (Đánh nhanh)",
   CurrentValue = false,
   Flag = "ToggleClick", 
   Callback = function(Value)
      _G.AutoClick = Value
      spawn(function()
         while _G.AutoClick do
            task.wait(0.1)
            pcall(function()
                -- Mã đánh chuẩn cho Blox Fruits
                game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Attack")
            end)
         end
      end)
   end,
})

-- ================= TAB NGƯỜI CHƠI =================
local PlayerTab = Window:CreateTab("Người Chơi", 4483362458)

PlayerTab:CreateSlider({
   Name = "Tốc độ chạy",
   Range = {16, 300},
   Increment = 1,
   Suffix = "Speed",
   CurrentValue = 16,
   Flag = "SliderSpeed",
   Callback = function(Value)
      game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = Value
   end,
})

PlayerTab:CreateButton({
   Name = "Nhảy cao",
   Callback = function()
       game.Players.LocalPlayer.Character.Humanoid.JumpPower = 100
   end,
})

-- QUAN TRỌNG: Dòng này để hoàn tất nạp giao diện
Rayfield:LoadConfiguration()
